---
import BaseLayout from "../layouts/baseLayout.astro";
---

<BaseLayout title="Vincent Acevedo Jr. | Gallery">


      <!-- gallery body -->
       <div id="gallery" class="aspect-square sm:aspect-video grid grid-cols-3 gap-5">
        
        <!-- 1st row -->
        <figure class="opacity-0 translate-y-6 transition-all duration-700 ease-out will-change-transform">
          <img loading="lazy" class="object-cover w-full h-full rounded border-4" src="/images/headshot1.jpg">
        </figure>

        <figure class="opacity-0 translate-y-6 transition-all duration-700 ease-out will-change-transform">
          <img loading="lazy" class="object-cover w-full h-full rounded border-4" src="/images/headshot2.jpg">
        </figure>

        <figure class="opacity-0 translate-y-6 transition-all duration-700 ease-out will-change-transform">
          <img loading="lazy" class="object-cover w-full h-full rounded border-4" src="/images/headshot3.jpg">
        </figure>

        <!-- 2nd row -->
        <figure class="opacity-0 translate-y-6 transition-all duration-700 ease-out will-change-transform">
          <img loading="lazy" class=" object-cover rounded border-4 space-x-3 w-full h-full" src="/images/jacket1.jpg">
        </figure>

        <figure class="opacity-0 translate-y-6 transition-all duration-700 ease-out will-change-transform">
          <img loading="lazy" class=" object-cover rounded border-4 w-full h-full" src="/images/jacket2.jpg">
        </figure>

        <figure class="opacity-0 translate-y-6 transition-all duration-700 ease-out will-change-transform">
          <img loading="lazy" class="object-cover w-full h-full rounded border-4" src="/images/jacket3.jpg">
        </figure>

        <!-- 3rd row -->
        <figure class="opacity-0 translate-y-6 transition-all duration-700 ease-out will-change-transform">
          <img loading="lazy" class="object-cover w-full h-full rounded border-4" src="/images/wideshot1.jpg">
        </figure>

        <figure class="opacity-0 translate-y-6 transition-all duration-700 ease-out will-change-transform">
          <img loading="lazy" class="object-cover w-full h-full rounded border-4" src="/images/wideshot2.jpg">
        </figure>

        <figure class="opacity-0 translate-y-6 transition-all duration-700 ease-out will-change-transform">
          <img loading="lazy" class="object-cover w-full h-full rounded border-4" src="/images/wideshot3.jpg">
        </figure>

        <!-- 4th row -->
        <figure class="opacity-0 translate-y-6 transition-all duration-700 ease-out will-change-transform">
          <img loading="lazy" class="object-cover w-full h-full rounded border-4" src="/images/wideshot5.jpg">
        </figure>

        <figure class="opacity-0 translate-y-6 transition-all duration-700 ease-out will-change-transform">
          <img loading="lazy" class="object-cover w-full h-full rounded border-4" src="/images/leavingchair.jpg">
        </figure>

        <figure class="opacity-0 translate-y-6 transition-all duration-700 ease-out will-change-transform">
          <img loading="lazy" class="object-cover w-full h-full rounded border-4" src="/images/leaningonwindow1.jpg">
        </figure>

        <!-- 5th row -->
        <figure class="opacity-0 translate-y-6 transition-all duration-700 ease-out will-change-transform">
          <img loading="lazy" class="object-cover w-full h-full rounded border-4" src="/images/jeanjacket1.jpg">
        </figure>

        <figure class="opacity-0 translate-y-6 transition-all duration-700 ease-out will-change-transform">
          <img loading="lazy" class="object-cover w-full h-full rounded border-4" src="/images/againstwall.jpg">
        </figure>

        <figure class="opacity-0 translate-y-6 transition-all duration-700 ease-out will-change-transform">
          <img loading="lazy" class="object-cover w-full h-full rounded border-4" src="/images/wideshot4.jpg">
        </figure>

       </div>



<!-- scripts -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Get all gallery items that should fade in
  const galleryItems = document.querySelectorAll('#gallery figure');
  
  // Create intersection observer
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        // Add visible classes with a slight delay for smoother effect
        setTimeout(() => {
          entry.target.classList.add('opacity-100', 'translate-y-0');
          entry.target.classList.remove('opacity-0', 'translate-y-6');
          
          // Stop observing this element once it's animated
          observer.unobserve(entry.target);
        }, 100);
      }
    });
  }, {
    // Only trigger when 30% of element is visible
    threshold: 0.3,
    // Add significant bottom margin so elements must scroll well into view
    rootMargin: '0px 0px -200px 0px'
  });

  // Ensure all items start hidden, then observe them
  galleryItems.forEach((item, index) => {
    // Make sure items start hidden
    item.classList.add('opacity-0', 'translate-y-6');
    item.classList.remove('opacity-100', 'translate-y-0');
    
    // Add transition classes if not already present
    if (!item.classList.contains('transition-all')) {
      item.classList.add('transition-all', 'duration-700', 'ease-out');
    }
    
    // Start observing each item
    observer.observe(item);
  });
});
</script>

</BaseLayout>