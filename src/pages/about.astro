---
import BaseLayout from "../layouts/baseLayout.astro";
import { Image } from "astro:assets";

// Film & TV thumbnails — drop your images in src/assets/credits/
import walkerImg from "../assets/credits/walker.jpg";
import partyPeopleImg from "../assets/credits/party-people.jpg";
import rowdyFewImg from "../assets/credits/rowdy-few.jpg";
import sunnyAfternoonImg from "../assets/credits/sunny-afternoon.jpg";
---

<BaseLayout title="Vincent Acevedo Jr. | About">

  <!-- Resume-style credits -->
  <section class="mx-auto w-full max-w-2xl space-y-6">

    <!-- Television -->
    <div class="bg-white/10 backdrop-blur-md ring-1 ring-white/30 rounded-2xl shadow-2xl p-6">
      <h2 class="text-xs uppercase tracking-widest text-white/50 mb-4">Television</h2>
      <div class="space-y-4">

        <div class="flex items-center gap-4">
          <Image
            src={walkerImg}
            alt="Walker"
            width={48}
            height={48}
            class="rounded-lg object-cover w-12 h-12 shrink-0 ring-1 ring-white/20"
          />
          <div class="flex-1 flex items-start justify-between gap-4">
            <div>
              <p class="text-white font-semibold">Walker</p>
              <p class="text-white/60 text-sm">CW · Dir. Clara Aranovich</p>
            </div>
            <span class="text-white/40 text-sm shrink-0">2023</span>
          </div>
        </div>

      </div>
    </div>

    <!-- Film -->
    <div class="bg-white/10 backdrop-blur-md ring-1 ring-white/30 rounded-2xl shadow-2xl p-6">
      <h2 class="text-xs uppercase tracking-widest text-white/50 mb-4">Film</h2>
      <div class="space-y-4">

        <div class="flex items-center gap-4">
          <Image
            src={partyPeopleImg}
            alt="Party People"
            width={48}
            height={48}
            class="rounded-lg object-cover w-12 h-12 shrink-0 ring-1 ring-white/20"
          />
          <div class="flex-1 flex items-start justify-between gap-4">
            <div>
              <p class="text-white font-semibold">Party People</p>
              <p class="text-white/60 text-sm">Lead · Dir. Joey LePage · Austin Film Festival</p>
            </div>
            <span class="text-white/40 text-sm shrink-0">2024</span>
          </div>
        </div>

        <div class="border-t border-white/10 pt-4 flex items-center gap-4">
          <Image
            src={rowdyFewImg}
            alt="The Rowdy Few"
            width={48}
            height={48}
            class="rounded-lg object-cover w-12 h-12 shrink-0 ring-1 ring-white/20"
          />
          <div class="flex-1 flex items-start justify-between gap-4">
            <div>
              <p class="text-white font-semibold">The Rowdy Few</p>
              <p class="text-white/60 text-sm">Lead · Director · Writer</p>
            </div>
            <span class="text-white/40 text-sm shrink-0">2026</span>
          </div>
        </div>

        <div class="border-t border-white/10 pt-4 flex items-center gap-4">
          <Image
            src={sunnyAfternoonImg}
            alt="Sunny Afternoon"
            width={48}
            height={48}
            class="rounded-lg object-cover w-12 h-12 shrink-0 ring-1 ring-white/20"
          />
          <div class="flex-1 flex items-start justify-between gap-4">
            <div>
              <p class="text-white font-semibold">Sunny Afternoon</p>
              <p class="text-white/60 text-sm">Lead · Dir. John Field Brown</p>
            </div>
            <span class="text-white/40 text-sm shrink-0">—</span>
          </div>
        </div>

      </div>
    </div>

    <!-- Training -->
    <div class="bg-white/10 backdrop-blur-md ring-1 ring-white/30 rounded-2xl shadow-2xl p-6">
      <h2 class="text-xs uppercase tracking-widest text-white/50 mb-4">Training</h2>
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-white font-semibold">In The Moment Acting Studio</p>
          <p class="text-white/60 text-sm">Acting</p>
        </div>
        <span class="text-white/40 text-sm shrink-0">2020 – 2023</span>
      </div>
    </div>

    <!-- Representation -->
    <div class="bg-white/10 backdrop-blur-md ring-1 ring-white/30 rounded-2xl shadow-2xl p-6">
      <h2 class="text-xs uppercase tracking-widest text-white/50 mb-4">Representation</h2>
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-white font-semibold">Collier Talent Agency</p>
          <p class="text-white/60 text-sm">Austin, Texas</p>
        </div>
      </div>
    </div>

  </section>

  <!-- Short bio -->
  <section class="mx-auto w-full max-w-2xl mt-6
                  bg-white/10 backdrop-blur-md ring-1 ring-white/30
                  rounded-2xl shadow-2xl p-6">
    <h2 class="text-xs uppercase tracking-widest text-white/50 mb-4">About</h2>
    <p class="text-white/80 text-base leading-relaxed">
      Vincent Acevedo Jr. is an actor, singer, and voice actor based in Austin, Texas.
      Trained at In The Moment Acting Studio, he has built a steady presence across
      independent film and network television — earning a role on the CW's
      <span class="text-white font-semibold">Walker</span> and leading the Austin Film
      Festival indie <span class="text-white font-semibold">Party People</span>.
      Represented by Collier Talent Agency, Vincent is always open to bold,
      story-driven collaborations.
    </p>
  </section>

  <!-- Call to action -->
  <section class="text-center mt-6">
    <p class="text-xl text-white mb-6">Interested in working together?</p>
    <a href="/contact"
       class="inline-block px-8 py-2 rounded-full
              bg-white/10 ring-1 ring-white/30 text-white
              hover:bg-white/20 hover:scale-105
              transition-all duration-200 shadow-lg">
      Get in Touch
    </a>
  </section>

</BaseLayout>