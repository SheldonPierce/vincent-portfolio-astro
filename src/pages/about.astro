---
import BaseLayout from "../layouts/baseLayout.astro";
---

<BaseLayout title="Vincent Acevedo Jr. | About">


      <!-- content -->

      <!-- Header -->
      <section class="text-center mb-16">
        <h1 class="text-3xl md:text-5xl font-extrabold tracking-widest mb-4
                   drop-shadow-[0_0_10px_rgba(255,255,255,0.8)]">
          About Vincent
        </h1>
      </section>

      <!-- Main content -->
      <section class="space-y-10 text-lg leading-relaxed font-semibold text-white
      mx-auto w-full max-w-xl
               bg-white/10 backdrop-blur-md
               ring-1 ring-white/30
               rounded-2xl shadow-2xl p-8 space-y-8">

        <p>
          Vincent Acevedo Jr. is a passionate performer with a deep love for both
          <span class="font-semibold text-white">stage and screen</span>.
          From intimate theatrical performances to dynamic on-camera work,
          Vincent brings authenticity, emotional depth, and bold character choices
          to every role.
        </p>

        <p>
          Trained through hands-on experience and continual exploration,
          Vincent thrives in collaborative environments and is driven by a desire
          to tell meaningful stories. Whether portraying grounded realism or heightened
          dramatic moments, his focus remains on honesty, presence, and connection.
        </p>

        <p>
          Beyond performance, Vincent is deeply interested in the creative process as a whole —
          from character development and storytelling to visual composition and mood.
          This holistic approach allows him to adapt quickly and bring intention to every project.
        </p>

        <p>
          When not performing, Vincent enjoys exploring creative outlets, staying physically active,
          and continuing to grow as an artist. He is always excited to collaborate on projects that
          challenge conventions and resonate with audiences.
        </p>

        </section>

      <!-- Call to action -->
      <section class="text-center">
        <p class="text-xl text-white mb-6 mt-6">
          Interested in working together?
        </p>
        <a href="/contact"
           class="inline-block px-8 py-2 rounded-full
                  bg-white/10 ring-1 ring-white/30 text-white
                  hover:bg-white/20 hover:scale-105
                  transition-all duration-200 shadow-lg">
          Get in Touch
        </a>
      </section>

</BaseLayout>