---
import Navbar from "../layouts/navbar.astro";
import Vantabackground from "../components/Vantabackground.astro";
import "../styles/global.css";

const { title = "Vincent Acevedo Jr." } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">
  </head>

  <body class="bg-gradient-to-l from-orange-500 to-blue-800 text-gray-300">
    <Vantabackground />

    <Navbar />

    <!-- Main content -->
    <main class="mx-auto p-4">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="text-center text-sm text-white/60 py-6 mt-8">
      &copy; {new Date().getFullYear()} Vincent Acevedo Jr. | All Rights Reserved
    </footer>

    <!-- Vanta scripts -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.fog.min.js"></script>

    <script is:inline>
      window.addEventListener("load", () => {
        if (window.VANTA) {
          window.VANTA.FOG({
            el: "#vanta-bg",
            mouseControls: true,
            touchControls: true,
            gyroControls: false,
            minHeight: 200.0,
            minWidth: 200.0,
            highlightColor: 0xfc9b62,
            midtoneColor: 0x1a00ff,
            blurFactor: 0.54,
            speed: 0.60,
            zoom: 1.10
          });
        }
      });
    </script>
  </body>
</html>